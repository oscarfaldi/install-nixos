#!/usr/bin/env bash

set -e

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo " Rainier Boot Rebuild"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo

echo "Building next generation..."
echo

sudo nixos-rebuild boot

echo
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo " Build Complete"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo

echo "Changes will apply after reboot."
echo

read -rp "Reboot now? [y/N]: " answer

case "$answer" in
[Yy]*)
sudo reboot
;;
*)
echo
echo "Reboot when ready."
;;
esac
