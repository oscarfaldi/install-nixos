#!/usr/bin/env bash

set -e

WALLPAPER_DIR="/etc/nixos/assets/wallpapers"

export AWWW_TRANSITION_FPS=60
export AWWW_TRANSITION_STEP=2

while true; do

    mapfile -t WALLPAPERS < <(
        find "$WALLPAPER_DIR" -type f \( \
            -iname "*.jpg" \
            -o -iname "*.jpeg" \
            -o -iname "*.png" \
            -o -iname "*.webp" \
        \) | shuf
    )

    [ "${#WALLPAPERS[@]}" -eq 0 ] && {
        sleep 1800
        continue
    }

    for WALLPAPER in "${WALLPAPERS[@]}"; do

        awww img "$WALLPAPER" \
            --transition-type grow \
            --transition-duration 1

        sleep 1800

    done

done
