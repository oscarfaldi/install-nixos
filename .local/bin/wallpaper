#!/usr/bin/env bash

set -e

WALLPAPER_DIR="/etc/nixos/assets/wallpapers"

mapfile -t WALLPAPERS < <(
    find "$WALLPAPER_DIR" -type f \( \
        -iname "*.jpg" \
        -o -iname "*.jpeg" \
        -o -iname "*.png" \
        -o -iname "*.webp" \
    \) | sort
)

[ "${#WALLPAPERS[@]}" -eq 0 ] && exit 0

CURRENT=$(awww query 2>/dev/null | awk -F': ' '/image:/ {print $2}')

while true; do
    SELECTED="${WALLPAPERS[RANDOM % ${#WALLPAPERS[@]}]}"

    [ "$SELECTED" != "$CURRENT" ] && break

    [ "${#WALLPAPERS[@]}" -eq 1 ] && break
done

awww img "$SELECTED" \
    --transition-type grow \
    --transition-duration 1 \
    --transition-fps 60 \
    --transition-step 2

notify-send \
    "Wallpaper Updated" \
    "$(basename "$SELECTED")"
