#!/usr/bin/env bash

# ==============================================================================
# Rainier Initialization & Setup Script
# 
# Description: Switches Rainier to unstable channel, installs home-manager,
#              imports hardware configuration, sets up SMB credentials,
#              and performs the initial system bootstrap.
# ==============================================================================

# Exit immediately if a command exits with a non-zero status
set -e

# ------------------------------------------------------------------------------
# Configuration & Variables
# ------------------------------------------------------------------------------
CONFIG_DIR="$HOME/System"
TARGET_CONFIG="./configuration.nix"
SMB_CRED_FILE="/etc/smb-credentials"
HW_CONFIG_SRC="/etc/nixos/hardware-configuration.nix"
HW_CONFIG_DST="./hardware-configuration.nix"

# ------------------------------------------------------------------------------
# UI Helper Functions
# ------------------------------------------------------------------------------
print_header() {
    local title="$1"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo " $title"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo
}

# ------------------------------------------------------------------------------
# Core Setup Functions
# ------------------------------------------------------------------------------
import_hardware_config() {
    print_header "Import Hardware Configuration"

    if [[ -f "$HW_CONFIG_SRC" ]]; then
        echo "Found hardware configuration in /etc/nixos"

        cp "$HW_CONFIG_SRC" "$HW_CONFIG_DST"

        echo "✓ Hardware configuration imported to repository."

    elif [[ -f "$HW_CONFIG_DST" ]]; then
        echo "✓ Hardware configuration already exists in repository."
        echo "  Skipping import."

    else
        echo "✗ hardware-configuration.nix not found anywhere."
        echo "  Checked:"
        echo "    - $HW_CONFIG_SRC"
        echo "    - $HW_CONFIG_DST"
        exit 1
    fi

    echo
    echo "Cleaning /etc/nixos ..."

    sudo find /etc/nixos -mindepth 1 -delete

    echo "✓ /etc/nixos cleaned."
    echo
}

fix_ownership() {
    print_header "Repository Ownership"

    if find "$CONFIG_DIR" -user root | grep -q .; then
        echo "Root-owned files detected."

        sudo chown -R "$(id -un):$(id -gn)" "$CONFIG_DIR"

        echo "✓ Ownership fixed."
    else
        echo "✓ Ownership already correct."
    fi

    echo
}

configure_nix_channels() {
    print_header "Channels Configuration"
    echo "Updating Nix channels to unstable..."
    echo

    # Safely remove existing channels if they exist
    sudo nix-channel --remove nixos 2>/dev/null || true
    sudo nix-channel --remove home-manager 2>/dev/null || true

    # Add unstable and home-manager channels
    sudo nix-channel --add https://channels.nixos.org/nixos-unstable nixos
    sudo nix-channel --add https://github.com/nix-community/home-manager/archive/master.tar.gz home-manager
    
    # Update channels to apply changes
    sudo nix-channel --update
    echo
    echo "✓ Unstable channel and home-manager enabled."
    echo
}

setup_smb_credentials() {
    print_header "SMB Credentials Setup"

    if [[ ! -f "$SMB_CRED_FILE" ]]; then
        echo "SMB credential file not found."
        echo
        
        read -rp "SMB Username: " SMB_USER
        read -rsp "SMB Password: " SMB_PASS
        echo

        # Securely write credentials to the target file
        sudo tee "$SMB_CRED_FILE" >/dev/null <<EOF
username=${SMB_USER}
password=${SMB_PASS}
EOF
        # Restrict permissions so only root can read/write
        sudo chmod 600 "$SMB_CRED_FILE"

        echo
        echo "✓ SMB credentials saved."
        echo
    else
        echo "✓ Existing SMB credentials found."
        echo
    fi
}

restore_libreoffice() {
    print_header "LibreOffice Configuration"

    mkdir -p "$HOME/.config/libreoffice/4/user"

    if [[ -f "$CONFIG_DIR/.config/libreoffice/4/user/registrymodifications.xcu" ]]; then
        cp -f \
            "$CONFIG_DIR/.config/libreoffice/4/user/registrymodifications.xcu" \
            "$HOME/.config/libreoffice/4/user/registrymodifications.xcu"

        echo "✓ LibreOffice settings restored."
    else
        echo "• No LibreOffice settings found."
    fi

    echo
}

bootstrap_system() {
    print_header "Rebuilding Rainier System"
    echo "Building next generation for boot..."
    echo

    # Execute NixOS boot build with explicit configuration path
    sudo nixos-rebuild boot \
        -I nixos-config="$TARGET_CONFIG"
    echo
    echo "✓ System rebuilt."
    echo
}

# ------------------------------------------------------------------------------
# Main Execution Flow
# ------------------------------------------------------------------------------
main() {
    print_header "Switching Rainier to unstable & installing home-manager"

    echo "Please authenticate once for the installation."
    echo

    sudo -v

    while true; do
        sudo -n true
        sleep 60
        kill -0 "$$" || exit
    done 2>/dev/null &

    import_hardware_config
    configure_nix_channels
    setup_smb_credentials
    restore_libreoffice
    bootstrap_system

    print_header "Final Step"
    echo "Rebooting in 5 seconds..."
    echo

    sleep 5
    sudo reboot
}

main "$@"
