#!/usr/bin/env bash

# ============================================================
# Wallpaper Rotation Daemon
# Continuously rotates wallpapers from the active theme
# and automatically reloads when the theme changes.
# ============================================================

set -e

STATE="$HOME/.local/state/current-theme"

export AWWW_TRANSITION_FPS=60
export AWWW_TRANSITION_STEP=2

while true; do

    THEME=$(cat "$STATE" 2>/dev/null || echo graphite)

    WALLPAPER_DIR="/etc/nixos/assets/themes/$THEME/wallpapers"

    mapfile -t WALLPAPERS < <(
        find "$WALLPAPER_DIR" -type f \( \
            -iname "*.jpg" \
            -o -iname "*.jpeg" \
            -o -iname "*.png" \
            -o -iname "*.webp" \
        \) | shuf
    )

    [ "${#WALLPAPERS[@]}" -eq 0 ] && {
        sleep 1800
        continue
    }

    for WALLPAPER in "${WALLPAPERS[@]}"; do

        CURRENT_THEME=$(cat "$STATE" 2>/dev/null || echo graphite)

        if [[ "$CURRENT_THEME" != "$THEME" ]]; then
            break
        fi

        awww img "$WALLPAPER" \
            --transition-type grow \
            --transition-duration 1

        sleep 1800

    done

done
