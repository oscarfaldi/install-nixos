#!/usr/bin/env bash

set -euo pipefail

FILE="$1"

DIR="$(dirname "$FILE")"
NAME="$(basename "$FILE")"

OUTPUT="${DIR}/${NAME%.*}_rotated.${NAME##*.}"

if ffmpeg \
    -i "$FILE" \
    -c copy \
    -metadata:s:v rotate=270 \
    "$OUTPUT" \
    -y >/dev/null 2>&1
then
    notify-send \
        -i video-x-generic \
        "Video Rotation" \
        "Rotated 90° counter-clockwise."
else
    notify-send \
        -i dialog-error \
        "Video Rotation" \
        "Rotation failed."
fi
