#!/usr/bin/env bash

# ==============================================================================
# Script Name: Open as Root
# Description: Opens the selected directory or file inside Thunar with root privileges
# ==============================================================================

set -euo pipefail

# 0. Safety Check: If no target is passed, default to current user's home directory
#    This prevents pkexec from opening an empty/error target.
TARGET="${1:-$HOME}"

# Execute Thunar as root via Polkit
pkexec thunar "$TARGET"
