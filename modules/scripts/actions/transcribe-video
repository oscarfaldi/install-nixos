#!/usr/bin/env python
from pathlib import Path
from faster_whisper import WhisperModel
import subprocess
import sys
import time

# ============================================================
# Configuration
# ============================================================
MODEL = "large-v3"
LANGUAGE = "id"
DEVICE = "cpu"
VIDEO_EXTENSIONS = {
    ".mp4",
    ".mov",
    ".mkv",
    ".avi",
    ".webm",
    ".mts",
    ".m4v",
}

# ============================================================
# Notifications
# ============================================================
def notify(title: str, message: str):
    try:
        subprocess.run(
            ["notify-send", title, message],
            check=False,
        )
    except Exception:
        pass

def zenity_success(message: str):
    try:
        subprocess.run(
            [
                "zenity",
                "--info",
                "--title",
                "Subtitle Ready",
                "--text",
                message,
                "--width=450",
            ],
            check=False,
        )
    except Exception:
        pass

def zenity_error(message: str):
    try:
        subprocess.run(
            [
                "zenity",
                "--error",
                "--title",
                "Subtitle Generation Failed",
                "--text",
                message,
                "--width=500",
            ],
            check=False,
        )
    except Exception:
        pass

# ============================================================
# SRT Helpers
# ============================================================
def format_timestamp(seconds: float) -> str:
    milliseconds = int(round(seconds * 1000))
    hours = milliseconds // 3600000
    milliseconds %= 3600000

    minutes = milliseconds // 60000
    milliseconds %= 60000

    secs = milliseconds // 1000
    milliseconds %= 1000

    return (
        f"{hours:02}:{minutes:02}:{secs:02},{milliseconds:03}"
    )

def next_available_srt(video_path: Path) -> Path:
    first = video_path.with_suffix(".srt")

    if not first.exists():
        return first

    counter = 1

    while True:
        candidate = (
            video_path.parent
            / f"{video_path.stem} ({counter}).srt"
        )

        if not candidate.exists():
            return candidate

        counter += 1

# ============================================================
# Validation
# ============================================================
if len(sys.argv) != 2:
    sys.exit(1)

video_path = Path(sys.argv[1]).expanduser()

if not video_path.exists():
    message = f"File not found:\n{video_path}"

    notify(
        "Subtitle Generation Failed",
        video_path.name,
    )

    zenity_error(message)

    sys.exit(1)

if video_path.suffix.lower() not in VIDEO_EXTENSIONS:
    message = (
        f"Unsupported file type:\n"
        f"{video_path.suffix}"
    )

    notify(
        "Subtitle Generation Failed",
        video_path.name,
    )

    zenity_error(message)

    sys.exit(1)

# ============================================================
# Processing
# ============================================================
srt_path = next_available_srt(video_path)

notify(
    "Generating Subtitle",
    video_path.name,
)

start_time = time.time()

try:
    model = WhisperModel(
        MODEL,
        device=DEVICE,
    )

    segments, info = model.transcribe(
        str(video_path),
        language=LANGUAGE,
    )

    with open(
        srt_path,
        "w",
        encoding="utf-8",
    ) as srt:

        for index, segment in enumerate(
            segments,
            start=1,
        ):
            srt.write(f"{index}\n")

            srt.write(
                f"{format_timestamp(segment.start)} --> "
                f"{format_timestamp(segment.end)}\n"
            )

            srt.write(
                segment.text.strip()
            )

            srt.write("\n\n")

except Exception as error:
    notify(
        "Subtitle Generation Failed",
        video_path.name,
    )

    zenity_error(str(error))

    raise

# ============================================================
# Completion
# ============================================================
elapsed = round(
    time.time() - start_time
)

notify(
    "Subtitle Ready",
    srt_path.name,
)

zenity_success(
    (
        f"Subtitle generated successfully.\n\n"
        f"File:\n{srt_path.name}\n\n"
        f"Time:\n{elapsed} seconds"
    )
)

print(
    f"Subtitle saved: {srt_path}"
)
