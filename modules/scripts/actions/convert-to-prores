#!/usr/bin/env bash

# ============================================================
# Functions
# ============================================================

run_ffmpeg() {
    local input="$1"
    local output="$2"

    # Launch Ghostty and monitor the FFmpeg process
    ghostty \
        --title="ProRes Conversion" \
        -e bash -c "
            ffmpeg \
                -hide_banner \
                -stats_period 1 \
                -i \"$input\" \
                -map 0:v:0 \
                -map '0:a?' \
                -sn \
                -dn \
                -c:v prores_ks \
                -profile:v 2 \
                -pix_fmt yuv422p10le \
                -c:a pcm_s24le \
                \"$output\"

            # Capture the exit status of the FFmpeg command
            STATUS=\$?

            # If FFmpeg fails, keep the terminal open for 5 seconds to inspect errors
            if [ \$STATUS -ne 0 ]; then
                echo -e '\n\e[1;31m[ERROR] FFmpeg conversion failed!\e[0m'
                echo 'Closing window in 5 seconds...'
                sleep 5
            fi

            # Forward the exit status out of Ghostty
            exit \$STATUS
        "
}

notify() {
    local title="$1"
    local message="$2"
    notify-send "$title" "$message"
}

# ============================================================
# Main
# ============================================================

# Ensure the input argument from Thunar or CLI is present
if [ -z "$1" ]; then
    notify "Error" "No input file specified."
    exit 1
fi

input="$1"

# Generate output filename (appends _prores.mov to the base name)
output="${input%.*}_prores.mov"

# Execute conversion and handle results
if run_ffmpeg "$input" "$output"; then
    # Match the timestamp of the output file with the original file
    touch -r "$input" "$output"

    notify \
        "Conversion Complete" \
        "$(basename "$output")"
else
    # Remove corrupt or incomplete output file on failure
    rm -f "$output"

    notify \
        "Conversion Failed" \
        "$(basename "$input")"
fi
