#!/usr/bin/env bash

# ==============================================================================
# CONFIGURATION & VARIABLES
# ==============================================================================
NAS="10.10.20.10"

shares=(
    academy
    archive
    download
    family
    games
    media
    mulino
    oscarfaldi
    personalbranding
    snapshot
    toolkit
    valhalla
)

# ==============================================================================
# NOTIFICATION FUNCTION
# ==============================================================================
notify() {
    notify-send \
        -u critical \
        -i network-server \
        "$1" \
        "$2"
}

# ==============================================================================
# NAS REACHABILITY CHECK
# ==============================================================================
if ! timeout 2 ping -c 1 "$NAS" >/dev/null 2>&1; then
    notify \
        "NAS Offline" \
        "Cannot reach $NAS. Check power, network connection, or IP address."
    exit 1
fi

# ==============================================================================
# SMB SERVICE CHECK
# ==============================================================================
if ! timeout 2 nc -z "$NAS" 445 >/dev/null 2>&1; then
    notify \
        "SMB Service Unavailable" \
        "Server is reachable, but SMB (port 445) is not responding."
    exit 1
fi

# ==============================================================================
# AUTHENTICATION CHECK
# ==============================================================================
if ! timeout 10 gio list "smb://$NAS" >/dev/null 2>&1; then
    notify \
        "SMB Authentication Required" \
        "Open Thunar and sign in once to save SMB credentials."
    exit 1
fi

# ==============================================================================
# MOUNT EXPECTED SHARES
# ==============================================================================
failed=()

for share in "${shares[@]}"; do
    if gio mount -l | grep -q "smb://$NAS/$share/"; then
        continue
    fi

    if ! timeout 10 gio mount "smb://$NAS/$share" >/dev/null 2>&1; then
        failed+=("$share")
    fi
done

# ==============================================================================
# VERIFY MOUNT OUTCOMES
# ==============================================================================

# Case 1: All Shares Mounted Successfully
if [ ${#failed[@]} -eq 0 ]; then
    exit 0
fi

# Case 2: Total Failure (No Configured Shares Could Be Mounted)
if [ ${#failed[@]} -eq ${#shares[@]} ]; then
    notify \
        "NAS Shares Unavailable" \
        "Connected successfully, but none of the configured SMB shares could be mounted."
    exit 1
fi

# Case 3: Partial Share Failure
notify \
    "Some NAS Shares Unavailable" \
    "Failed shares: ${failed[*]}"
exit 1
