#!/usr/bin/env bash

set -e

REPO_DIR="/etc/nixos"

echo
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo " Rainier Bootstrap"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo

# ============================================================

# Dotfiles

# ============================================================

echo "Installing user configuration..."

mkdir -p "$HOME/.config"

if [ -d "$REPO_DIR/dotfiles" ]; then
cp -rf "$REPO_DIR/dotfiles/"* "$HOME/.config/"
fi

echo
echo "✓ Dotfiles installed."
echo

# ============================================================

# Local Utilities

# ============================================================

echo "Installing local utilities..."

mkdir -p "$HOME/.local"

if [ -d "$REPO_DIR/.local" ]; then
cp -rf "$REPO_DIR/.local/"* "$HOME/.local/"
fi

echo
echo "✓ Local utilities installed."
echo

# ============================================================

# User Directories

# ============================================================

echo "Checking user directories..."

mkdir -p 
"$HOME/Documents" 
"$HOME/Downloads" 
"$HOME/Music" 
"$HOME/Pictures" 
"$HOME/Videos" 
"$HOME/Games" 
"$HOME/Templates"

echo
echo "✓ User directories ready."
echo

# ============================================================

# NetworkManager Cleanup

# ============================================================

echo "Cleaning NetworkManager..."

nmcli -t -f NAME connection show 2>/dev/null | while read -r conn; do
case "$conn" in
Wired\ connection*)
nmcli connection delete "$conn" >/dev/null 2>&1 || true
;;
esac
done

echo
echo "✓ NetworkManager cleaned."
echo

# ============================================================

# Finished

# ============================================================

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo " Bootstrap Complete"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo

echo "Rainier is configured."
echo
echo "Installed:"
echo "  • Dotfiles"
echo "  • Local utilities"
echo "  • User directories"
echo
echo "Next boot will activate:"
echo "  • Theme"
echo "  • Wallpaper"
echo "  • Startup services"
echo
echo "Rebooting in 10 seconds..."
echo "Press Ctrl+C to cancel."
echo

sleep 10

sudo reboot
