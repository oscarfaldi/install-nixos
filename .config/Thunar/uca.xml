  <!-- ========================================== -->
  <!-- 5. VIDEO PROCESSING                        -->
  <!-- ========================================== -->

  <action>
    <icon>object-rotate-right</icon>
    <name>Rotate Video Right</name>
    <submenu>Media</submenu>
    <unique-id>1781935446753343-501</unique-id>
    <command>rotate-video-right %f</command>
    <description>Rotate video 90° clockwise</description>
    <range>*</range>
    <patterns>*.mp4;*.MP4;*.mov;*.MOV;*.mkv;*.MKV;*.webm;*.mts;*.m2ts;*.ts</patterns>
    <video-files/>
  </action>

  <action>
    <icon>object-rotate-left</icon>
    <submenu>Media</submenu>
    <name>Rotate Video Left</name>
    <unique-id>1781935446753343-502</unique-id>
    <command>rotate-video-left %f</command>
    <description>Rotate video 90° counter-clockwise</description>
    <range>*</range>
    <patterns>*.mp4;*.MP4;*.mov;*.MOV;*.mkv;*.MKV;*.webm;*.mts;*.m2ts;*.ts</patterns>
    <video-files/>
