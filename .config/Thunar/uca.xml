  <action>
    <icon>video-x-generic</icon>
    <name>Rename TS → MTS</name>
    <submenu>Media</submenu>
    <unique-id>1781935446753343-503</unique-id>
    <command>rename-ts-to-mts %F</command>
    <description>Rename TS files for better thumbnail and MIME support</description>
    <range>*</range>
    <patterns>*.ts</patterns>
    <other-files/>
  </action>

  <!-- ========================================== -->
  <!-- 6. VIDEO PROCESSING                        -->
  <!-- ========================================== -->
  
  <action>
    <icon>applications-multimedia</icon>
    <name>Convert to ProRes 422 HQ</name>
    <submenu>Content Creation</submenu>
    <unique-id>1781935446753343-601</unique-id>
    <command>convert-to-prores %F</command>
    <description>Convert selected videos to Apple ProRes 422 HQ for DaVinci Resolve</description>
    <range>*</range>
    <patterns>*.mp4;*.MP4;*.mov;*.MOV;*.mkv;*.MKV;*.webm;*.mts;*.m2ts;*.ts;*.avi;*.mxf;*.m4v</patterns>
    <video-files/>
  </action>

    <action>
    <icon>applications-multimedia</icon>
    <name>Convert to ProRes 422 HQ (Monitor)</name>
    <submenu>Content Creation</submenu>
    <unique-id>1781935446753343-602</unique-id>
    <command>ghostty --title="ProRes Conversion" -e convert-to-prores %F</command>
    <description>Convert selected videos to Apple ProRes 422 HQ for DaVinci Resolve with live monitoring</description>
    <range>*</range>
    <patterns>*.mp4;*.MP4;*.mov;*.MOV;*.mkv;*.MKV;*.webm;*.mts;*.m2ts;*.ts;*.avi;*.mxf;*.m4v</patterns>
    <video-files/>
  </action>

  <action>
    <icon>applications-multimedia</icon>
    <name>Transcribe Video to SRT</name>
    <submenu>Content Creation</submenu>
    <unique-id>1781935446753343-603</unique-id>
    <command>transcribe-video %F</command>
    <description>Generate Indonesian SRT subtitles using Faster-Whisper</description>
    <range>*</range>
    <patterns>*.mp4;*.MP4;*.mov;*.MOV;*.mkv;*.MKV;*.webm;*.mts;*.m2ts;*.ts;*.avi;*.mxf;*.m4v</patterns>
    <video-files/>
  </action>

    <action>
    <icon>applications-multimedia</icon>
    <name>Transcribe Video to SRT (Monitor)</name>
    <submenu>Content Creation</submenu>
    <unique-id>1781935446753343-604</unique-id>
    <command>ghostty --title="Subtitle Generation" -e transcribe-video %F</command>
    <description>Generate Indonesian SRT subtitles using Faster-Whisper with live monitoring</description>
    <range>*</range>
    <patterns>*.mp4;*.MP4;*.mov;*.MOV;*.mkv;*.MKV;*.webm;*.mts;*.m2ts;*.ts;*.avi;*.mxf;*.m4v</patterns>
    <video-files/>
  </action>

