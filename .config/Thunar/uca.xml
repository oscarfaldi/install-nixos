  </action>

  <action>
    <icon>image-x-generic</icon>
    <name>Convert to JPEG</name>
    <submenu>Media</submenu>
    <unique-id>1781935446753343-403</unique-id>
    <command>convert-to-jpeg %F</command>
    <description>Convert image to JPEG</description>
    <range>*</range>
    <patterns>*.jpg;*.jpeg;*.png;*.webp;*.avif;*.gif;*.bmp;*.tif;*.tiff;*.svg;*.heic;*.heif</patterns>
