  <action>
    <icon>object-rotate-right</icon>
    <name>Rotate Image Right</name>
    <submenu>Media</submenu>
    <unique-id>1781935446753343-404</unique-id>
    <command>rotate-image-right %f</command>
    <description>Rotate image 90° clockwise</description>
    <range>*</range>
    <patterns>*.jpg;*.jpeg;*.png;*.gif;*.webp;*.avif;*.bmp;*.tif;*.tiff</patterns>
