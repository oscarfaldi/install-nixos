<?xml version="1.0" encoding="UTF-8"?>
<actions>

  <!-- ========================================== -->
  <!-- 1. CORE SYSTEM ACTIONS                     -->
  <!-- ========================================== -->

  <action>
    <icon>utilities-terminal</icon>
    <name>Open Terminal Here</name>
    <submenu/>
    <unique-id>1781935446753343-101</unique-id>
    <command>exo-open --working-directory %f --launch TerminalEmulator</command>
    <description>Open terminal in current folder</description>
    <range></range>
    <patterns>*</patterns>
    <startup-notify/>
    <directories/>
  </action>

  <action>
    <icon>dialog-information</icon>
    <name>Inspect File</name>
    <unique-id>1781935446753343-102</unique-id>
    <command>inspect-file %f</command>
    <description>Show detailed file information and metadata</description>
    <range>*</range>
    <patterns>*</patterns>
    <directories/>
    <audio-files/>
    <image-files/>
    <other-files/>
    <text-files/>
    <video-files/>
  </action>
  
  <!-- ========================================== -->
  <!-- 2. CLIPBOARD & PATH MANAGEMENT             -->
  <!-- ========================================== -->

  <action>
    <icon>edit-copy</icon>
    <name>Copy Full Path</name>
    <submenu>Clipboard</submenu>
    <unique-id>1781935446753343-201</unique-id>
    <command>copy-full-path %f</command>
    <description>Copy full file path</description>
    <range>*</range>
    <patterns>*</patterns>
    <directories/>
    <audio-files/>
    <image-files/>
    <other-files/>
    <text-files/>
    <video-files/>
  </action>

  <action>
    <icon>edit-copy</icon>
    <name>Copy Filename</name>
    <submenu>Clipboard</submenu>
    <unique-id>1781935446753343-202</unique-id>
    <command>copy-filename %f</command>
    <description>Copy filename</description>
    <range>*</range>
    <patterns>*</patterns>
    <directories/>
    <audio-files/>
    <image-files/>
    <other-files/>
    <text-files/>
    <video-files/>
  </action>

  <action>
    <icon>edit-copy</icon>
    <name>Copy Filename Without Extension</name>
    <submenu>Clipboard</submenu>
    <unique-id>1781935446753343-203</unique-id>
    <command>copy-filename-no-extension %f</command>
    <description>Copy filename without extension</description>
    <range>*</range>
    <patterns>*</patterns>
    <directories/>
    <audio-files/>
    <image-files/>
    <other-files/>
    <text-files/>
    <video-files/>
  </action>

  <!-- ========================================== -->
  <!-- 3. DOCUMENT & ARCHIVE UTILITIES            -->
  <!-- ========================================== -->

  <action>
    <icon>application-pdf</icon>
    <name>Convert to PDF</name>
    <submenu>Documents</submenu>
    <unique-id>1781935446753343-301</unique-id>
    <command>convert-to-pdf %F</command>
    <description>Convert text or images to PDF</description>
    <range>*</range>
    <patterns>*.md;*.txt;*.jpg;*.jpeg;*.png;*.tif;*.tiff</patterns>
    <other-files/>
    <text-files/>
    <image-files/>
  </action>

  <action>
    <icon>folder-remote</icon>
    <name>Move to NAS Valhalla Videos Staging</name>
    <submenu>NAS</submenu>
    <unique-id>1782052090035038-302</unique-id>
    <command>move-to-valhalla-videos-staging %F</command>
    <description>Move selected video files to NAS staging area</description>
    <range>*</range>
    <patterns>
        *.mp4;*.MP4;*.mov;*.MOV;
        *.mkv;*.MKV;*.webm;*.avi;
        *.flv;*.wmv;*.m4v;*.mts;
        *.m2ts;*.ts;*.mpeg;
        *.mpg;*.3gp;*.ogv
    </patterns>
    <image-files/>
    <video-files/>
  </action>
  
  <action>
    <icon>folder-remote</icon>
    <name>Move to NAS Valhalla Pictures Staging</name>
    <submenu>NAS</submenu>
    <unique-id>1782052090035038-303</unique-id>
    <command>move-to-valhalla-pictures-staging %F</command>
    <description>Move selected media files to NAS staging area</description>
    <range>*</range>
    <patterns>
        *.mp4;*.MP4;*.mov;*.MOV;
        *.mkv;*.MKV;*.webm;*.avi;
        *.flv;*.wmv;*.m4v;*.mts;
        *.m2ts;*.ts;*.mpeg;
        *.mpg;*.3gp;*.ogv
    </patterns>
    <image-files/>
    <video-files/>
  </action>
  
  <action>
    <icon>package-x-generic</icon>
    <name>Compress to ZIP</name>
    <submenu>Documents</submenu>
    <unique-id>1781935446753343-304</unique-id>
    <command>compress-to-zip %F</command>
    <description>Create ZIP archive from selected files</description>
    <range>*</range>
    <patterns>*</patterns>
    <directories/>
    <audio-files/>
    <image-files/>
    <other-files/>
    <text-files/>
    <video-files/>
  </action>

  <action>
    <icon>package-x-generic</icon>
    <name>Extract Archive Here</name>
    <submenu>Documents</submenu>
    <unique-id>1781935446753343-305</unique-id>
    <command>extract-here %f</command>
    <description>Extract archive contents into current folder</description>
    <range>*</range>
    <patterns>*.zip;*.7z;*.rar;*.tar;*.tar.gz;*.tgz;*.tar.xz</patterns>
    <other-files/>
  </action>

