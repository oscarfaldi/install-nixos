    <unique-id>1781935446753343-401</unique-id>
    <command>convert-to-avif %F</command>
    <description>Convert image to AVIF</description>
    <range>*</range>
    <patterns>*.jpg;*.jpeg;*.png;*.webp;*.avif;*.gif;*.bmp;*.tif;*.tiff;*.svg;*.heic;*.heif</patterns>
    <image-files/>
  </action>

  <action>
    <icon>image-x-generic</icon>
    <name>Convert to PNG</name>
    <submenu>Media</submenu>
    <unique-id>1781935446753343-402</unique-id>
    <command>convert-to-png %F</command>
    <description>Convert image to PNG</description>
    <range>*</range>
    <patterns>*.jpg;*.jpeg;*.png;*.webp;*.avif;*.gif;*.bmp;*.tif;*.tiff;*.svg;*.heic;*.heif</patterns>
