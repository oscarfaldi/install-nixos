# Theme

theme = vintage

# Font

font-family = JetBrainsMono Nerd Font
font-size = 13
font-thicken = true

# Cursor

cursor-style = block
cursor-style-blink = false

custom-shader = shaders/cursor_warp.glsl
custom-shader-animation = always

# Appearance

background-opacity = 0.75
background-blur-radius = 50

window-padding-x = 12
window-padding-y = 12

# Behavior

mouse-hide-while-typing = true
window-save-state = always

# Navigation

keybind = ctrl+h=goto_split:left
keybind = ctrl+j=goto_split:bottom
keybind = ctrl+k=goto_split:top
keybind = ctrl+l=goto_split:right

keybind = super+h=previous_tab
keybind = super+l=next_tab

keybind = super+ctrl+h=resize_split:left,10
keybind = super+ctrl+j=resize_split:down,10
keybind = super+ctrl+k=resize_split:up,10
keybind = super+ctrl+l=resize_split:right,10

keybind = shift+enter=text:\n
